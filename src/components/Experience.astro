---
import { experience, education } from "../data/experience";
import SectionLabel from "./SectionLabel.astro";
---

<section id="experience" class="mx-auto max-w-5xl scroll-mt-20 px-5 pb-20 sm:px-8 sm:pb-28">
  <SectionLabel number="03" title="Experience" />

  <div class="mt-10 space-y-12">
    {
      experience.map((job) => (
        <div class="grid gap-3 border-b border-line pb-10 last:border-b-0 last:pb-0 md:grid-cols-[180px_1fr] md:gap-10">
          <p class="text-sm font-medium text-muted">{job.period}</p>
          <div>
            <h3 class="text-lg font-semibold text-ink-950">
              {job.role} <span class="font-normal text-muted">· {job.company}</span>
            </h3>
            <p class="mt-0.5 text-sm text-muted">{job.location}</p>
            <ul class="mt-4 space-y-2.5">
              {job.points.map((point) => (
                <li class="flex gap-3 leading-relaxed text-ink-700">
                  <span class="mt-2.5 h-1 w-1 shrink-0 rounded-full bg-accent-600" />
                  {point}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))
    }
  </div>

  <div class="mt-14 rounded-card border border-line bg-card p-6 sm:p-8">
    <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-ink-800">Education</h3>
    <div class="mt-5 grid gap-6 sm:grid-cols-3">
      {
        education.map((entry) => (
          <div>
            <p class="text-sm text-muted">{entry.period}</p>
            <p class="mt-1 font-medium leading-snug text-ink-950">{entry.title}</p>
            <p class="mt-1 text-sm text-muted">{entry.place}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
