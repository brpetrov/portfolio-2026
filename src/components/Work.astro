---
import { bartec, builds, sideProjects } from "../data/work";
import BuildCard from "./BuildCard.astro";
import Icon from "./Icon.astro";
import SectionLabel from "./SectionLabel.astro";

// First two rows (4 cards) of client/demo work are always visible; the rest
// sit behind a "Show more" toggle. Side projects get their own section.
const VISIBLE_COUNT = 4;
const visibleBuilds = builds.slice(0, VISIBLE_COUNT);
const hiddenBuilds = builds.slice(VISIBLE_COUNT);
---

<section id="work" class="mx-auto max-w-5xl scroll-mt-20 px-5 pb-20 sm:px-8 sm:pb-28">
  <SectionLabel number="01" title="Selected work" />

  <!-- Professional feature block -->
  <div class="mt-10 rounded-card bg-panel p-7 text-panel-fg sm:p-12">
    <p class="text-sm font-medium uppercase tracking-[0.15em] text-panel-fg/50">{bartec.kicker}</p>
    <h3 class="mt-4 font-display text-3xl sm:text-4xl">{bartec.title}</h3>
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-panel-fg/75">{bartec.description}</p>

    <div class="mt-10 grid gap-8 border-t border-white/10 pt-9 md:grid-cols-3">
      {
        bartec.projects.map((project) => (
          <div>
            <h4 class="text-lg font-semibold">{project.name}</h4>
            <p class="mt-1 text-xs font-medium uppercase tracking-wide text-panel-fg/45">{project.tech}</p>
            <p class="mt-3 text-sm leading-relaxed text-panel-fg/70">{project.text}</p>
          </div>
        ))
      }
    </div>

    <p class="mt-9 flex items-center gap-2 text-sm text-panel-fg/50">
      <Icon name="lock" size={15} />
      {bartec.note}
    </p>
  </div>

  <!-- Client & demo builds: first rows always visible -->
  <div class="mt-6 grid gap-6 md:grid-cols-2">
    {visibleBuilds.map((build) => <BuildCard build={build} />)}
  </div>

  <!-- Remaining builds, collapsed by default -->
  <div id="more-projects" class="mt-6 hidden grid-cols-1 gap-6 md:grid-cols-2">
    {hiddenBuilds.map((build) => <BuildCard build={build} />)}
  </div>

  <div class="mt-8 text-center">
    <button
      id="toggle-projects"
      type="button"
      aria-expanded="false"
      aria-controls="more-projects"
      data-more={`Show ${hiddenBuilds.length} more projects`}
      data-less="Show fewer projects"
      class="inline-flex items-center gap-2 rounded-full border border-line bg-card px-7 py-3 text-sm font-semibold text-ink-950 transition hover:border-ink-700"
    >
      Show {hiddenBuilds.length} more projects
      <svg id="toggle-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform" aria-hidden="true">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </button>
  </div>
</section>

<section id="side-projects" class="mx-auto max-w-5xl scroll-mt-20 px-5 pb-20 sm:px-8 sm:pb-28">
  <SectionLabel number="02" title="Side projects" />
  <p class="mt-6 max-w-2xl text-ink-700">
    Apps and tools I build and ship in my own time — currently two Flutter apps with Gemini AI
    integration and a browser extension.
  </p>

  <div class="mt-8 grid gap-6 md:grid-cols-2">
    {sideProjects.map((build) => <BuildCard build={build} />)}
  </div>
</section>

<script>
  // Show more / show fewer projects.
  const toggle = document.getElementById("toggle-projects");
  const more = document.getElementById("more-projects");
  const chevron = document.getElementById("toggle-chevron");
  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    more?.classList.toggle("hidden", expanded);
    more?.classList.toggle("grid", !expanded);
    toggle.setAttribute("aria-expanded", String(!expanded));
    const label = expanded ? toggle.dataset.more : toggle.dataset.less;
    if (label) toggle.childNodes[0].textContent = label + " ";
    chevron?.classList.toggle("rotate-180", !expanded);
    if (expanded) document.getElementById("work")?.scrollIntoView({ behavior: "smooth", block: "start" });
  });

  // Thumbnail gallery: clicking a thumb swaps the main image.
  document.querySelectorAll<HTMLElement>("[data-gallery]").forEach((gallery) => {
    const main = gallery.querySelector<HTMLImageElement>("[data-gallery-main]");
    const thumbs = Array.from(gallery.querySelectorAll<HTMLButtonElement>("button[data-src]"));
    if (!main) return;

    gallery.addEventListener("click", (event) => {
      const btn = (event.target as HTMLElement).closest<HTMLButtonElement>("button[data-src]");
      if (!btn || !gallery.contains(btn)) return;
      main.src = btn.dataset.src ?? main.src;
      main.alt = btn.dataset.alt ?? main.alt;
      for (const thumb of thumbs) {
        const active = thumb === btn;
        thumb.classList.toggle("border-accent-500", active);
        thumb.classList.toggle("border-line", !active);
        thumb.classList.toggle("opacity-60", !active);
      }
    });
  });
</script>
