---
import { bartec, builds, earlier } from "../data/work";
import { withBase } from "../lib/url";
import Icon from "./Icon.astro";
import SectionLabel from "./SectionLabel.astro";
---

<section id="work" class="mx-auto max-w-5xl scroll-mt-20 px-5 pb-20 sm:px-8 sm:pb-28">
  <SectionLabel number="01" title="Selected work" />

  <!-- Professional feature block -->
  <div class="mt-10 rounded-card bg-ink-950 p-7 text-paper sm:p-12">
    <p class="text-sm font-medium uppercase tracking-[0.15em] text-paper/50">{bartec.kicker}</p>
    <h3 class="mt-4 font-display text-3xl sm:text-4xl">{bartec.title}</h3>
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-paper/75">{bartec.description}</p>

    <div class="mt-10 grid gap-8 border-t border-white/10 pt-9 md:grid-cols-3">
      {
        bartec.projects.map((project) => (
          <div>
            <h4 class="text-lg font-semibold">{project.name}</h4>
            <p class="mt-1 text-xs font-medium uppercase tracking-wide text-paper/45">{project.tech}</p>
            <p class="mt-3 text-sm leading-relaxed text-paper/70">{project.text}</p>
          </div>
        ))
      }
    </div>

    <p class="mt-9 flex items-center gap-2 text-sm text-paper/50">
      <Icon name="lock" size={15} />
      {bartec.note}
    </p>
  </div>

  <!-- Public builds -->
  <div class="mt-6 grid gap-6 md:grid-cols-2">
    {
      builds.map((build) => (
        <article class="group flex flex-col overflow-hidden rounded-card border border-line bg-white transition hover:border-ink-700/40">
          {build.images.length > 1 ? (
            <div class="border-b border-line" data-gallery>
              <img
                data-gallery-main
                src={withBase(build.images[0].src)}
                alt={build.images[0].alt}
                width="1280"
                height="800"
                loading="lazy"
                class="aspect-[16/10] w-full object-cover object-top"
              />
              <div class="flex gap-2 border-t border-line bg-paper p-2">
                {build.images.map((img, i) => (
                  <button
                    type="button"
                    data-src={withBase(img.src)}
                    data-alt={img.alt}
                    aria-label={`Show screenshot: ${img.alt}`}
                    class:list={[
                      "overflow-hidden rounded-md border transition",
                      i === 0 ? "border-accent-500" : "border-line opacity-60 hover:opacity-100",
                    ]}
                  >
                    <img
                      src={withBase(img.src)}
                      alt=""
                      width="120"
                      height="75"
                      loading="lazy"
                      class="aspect-[16/10] h-12 w-auto object-cover object-top sm:h-14"
                    />
                  </button>
                ))}
              </div>
            </div>
          ) : build.images.length === 1 ? (
            <img
              src={withBase(build.images[0].src)}
              alt={build.images[0].alt}
              width="1280"
              height="800"
              loading="lazy"
              class="aspect-[16/10] w-full border-b border-line object-cover object-top"
            />
          ) : (
            <div class="flex aspect-[16/10] w-full flex-col items-start justify-end border-b border-line bg-ink-950 p-6">
              <p class="text-xs font-medium uppercase tracking-[0.15em] text-paper/40">{build.kicker}</p>
              <p class="mt-2 font-display text-3xl text-paper">{build.name}</p>
            </div>
          )}
          <div class="flex grow flex-col p-6 sm:p-7">
            <p class="text-xs font-medium uppercase tracking-[0.15em] text-muted">{build.kicker}</p>
            <h3 class="mt-2 font-display text-2xl text-ink-950">{build.name}</h3>
            <p class="mt-3 grow leading-relaxed text-ink-700">{build.text}</p>
            <p class="mt-4 text-sm text-muted">{build.tech.join(" · ")}</p>
            <div class="mt-5 flex gap-5 border-t border-line pt-4 text-sm font-semibold">
              {build.repoUrl && (
                <a href={build.repoUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-ink-950 hover:text-accent-600">
                  <Icon name="github" size={15} />
                  Source
                  <Icon name="arrow-up-right" size={13} class="text-muted" />
                </a>
              )}
              {build.liveUrl && (
                <a href={build.liveUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-ink-950 hover:text-accent-600">
                  Live site
                  <Icon name="arrow-up-right" size={13} class="text-muted" />
                </a>
              )}
              {!build.repoUrl && !build.liveUrl && (
                <span class="inline-flex items-center gap-1.5 font-medium text-muted">
                  <Icon name="lock" size={14} />
                  Private client project
                </span>
              )}
            </div>
          </div>
        </article>
      ))
    }
  </div>

  <!-- Earlier projects -->
  <div class="mt-14">
    <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-ink-800">Earlier projects</h3>
    <div class="mt-5 grid gap-x-8 gap-y-5 sm:grid-cols-3">
      {
        earlier.map((project) => (
          <div class="border-t border-line pt-4">
            <h4 class="font-semibold text-ink-950">{project.name}</h4>
            <p class="mt-1 text-sm leading-relaxed text-ink-700">{project.text}</p>
            <div class="mt-3 flex gap-4 text-sm font-semibold">
              <a href={project.liveUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-ink-950 hover:text-accent-600">
                Live
                <Icon name="arrow-up-right" size={12} class="text-muted" />
              </a>
              <a href={project.repoUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-ink-950 hover:text-accent-600">
                Source
                <Icon name="arrow-up-right" size={12} class="text-muted" />
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  // Thumbnail gallery: clicking a thumb swaps the main image.
  document.querySelectorAll<HTMLElement>("[data-gallery]").forEach((gallery) => {
    const main = gallery.querySelector<HTMLImageElement>("[data-gallery-main]");
    const thumbs = Array.from(gallery.querySelectorAll<HTMLButtonElement>("button[data-src]"));
    if (!main) return;

    gallery.addEventListener("click", (event) => {
      const btn = (event.target as HTMLElement).closest<HTMLButtonElement>("button[data-src]");
      if (!btn || !gallery.contains(btn)) return;
      main.src = btn.dataset.src ?? main.src;
      main.alt = btn.dataset.alt ?? main.alt;
      for (const thumb of thumbs) {
        const active = thumb === btn;
        thumb.classList.toggle("border-accent-500", active);
        thumb.classList.toggle("border-line", !active);
        thumb.classList.toggle("opacity-60", !active);
      }
    });
  });
</script>
