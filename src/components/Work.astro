---
import { bartec, builds } from "../data/work";
import { withBase } from "../lib/url";
import Icon from "./Icon.astro";
import SectionLabel from "./SectionLabel.astro";
---

<section id="work" class="mx-auto max-w-5xl scroll-mt-20 px-5 pb-20 sm:px-8 sm:pb-28">
  <SectionLabel number="01" title="Selected work" />

  <!-- Professional feature block -->
  <div class="mt-10 rounded-card bg-ink-950 p-7 text-paper sm:p-12">
    <p class="text-sm font-medium uppercase tracking-[0.15em] text-paper/50">{bartec.kicker}</p>
    <h3 class="mt-4 font-display text-3xl sm:text-4xl">{bartec.title}</h3>
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-paper/75">{bartec.description}</p>

    <div class="mt-10 grid gap-8 border-t border-white/10 pt-9 md:grid-cols-3">
      {
        bartec.projects.map((project) => (
          <div>
            <h4 class="text-lg font-semibold">{project.name}</h4>
            <p class="mt-1 text-xs font-medium uppercase tracking-wide text-paper/45">{project.tech}</p>
            <p class="mt-3 text-sm leading-relaxed text-paper/70">{project.text}</p>
          </div>
        ))
      }
    </div>

    <p class="mt-9 flex items-center gap-2 text-sm text-paper/50">
      <Icon name="lock" size={15} />
      {bartec.note}
    </p>
  </div>

  <!-- Public builds -->
  <div class="mt-6 grid gap-6 md:grid-cols-2">
    {
      builds.map((build) => (
        <article class="group flex flex-col overflow-hidden rounded-card border border-line bg-white transition hover:border-ink-700/40">
          <a href={build.repoUrl} target="_blank" rel="noopener" class="block overflow-hidden border-b border-line">
            <img
              src={withBase(build.image)}
              alt={build.imageAlt}
              width="1280"
              height="800"
              loading="lazy"
              class="aspect-[16/10] w-full object-cover object-top transition duration-300 group-hover:scale-[1.02]"
            />
          </a>
          <div class="flex grow flex-col p-6 sm:p-7">
            <p class="text-xs font-medium uppercase tracking-[0.15em] text-muted">{build.kicker}</p>
            <h3 class="mt-2 font-display text-2xl text-ink-950">{build.name}</h3>
            <p class="mt-3 grow leading-relaxed text-ink-700">{build.text}</p>
            <p class="mt-4 text-sm text-muted">{build.tech.join(" · ")}</p>
            <div class="mt-5 flex gap-5 border-t border-line pt-4 text-sm font-semibold">
              <a href={build.repoUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-ink-950 hover:text-accent-600">
                <Icon name="github" size={15} />
                Source
                <Icon name="arrow-up-right" size={13} class="text-muted" />
              </a>
              {build.liveUrl && (
                <a href={build.liveUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-ink-950 hover:text-accent-600">
                  Live site
                  <Icon name="arrow-up-right" size={13} class="text-muted" />
                </a>
              )}
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
