---
import { profile } from "../data/profile";
import Icon from "./Icon.astro";
---

<header class="sticky top-0 z-50 border-b border-line bg-paper/90 backdrop-blur">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4 sm:px-8">
    <a href="#top" class="text-lg font-semibold tracking-tight text-ink-950">Boyan Petrov</a>

    <nav class="flex items-center gap-5 text-sm font-medium text-ink-700 sm:gap-6">
      <a href="#work" data-spy="work" class="nav-link hidden sm:inline">Work</a>
      <a href="#side-projects" data-spy="side-projects" class="nav-link hidden md:inline">Side projects</a>
      <a href="#experience" data-spy="experience" class="nav-link hidden sm:inline">Experience</a>
      <a href="#skills" data-spy="skills" class="nav-link hidden sm:inline">Skills</a>
      <a href="#contact" data-spy="contact" class="nav-link">Contact</a>
      <a
        href={profile.github}
        target="_blank"
        rel="noopener"
        aria-label="GitHub profile"
        class="text-ink-700 transition hover:text-ink-950"
      >
        <Icon name="github" size={19} />
      </a>
      <a
        href={profile.linkedin}
        target="_blank"
        rel="noopener"
        aria-label="LinkedIn profile"
        class="text-ink-700 transition hover:text-ink-950"
      >
        <Icon name="linkedin" size={19} />
      </a>
      <button
        id="theme-toggle"
        type="button"
        aria-label="Switch between light and dark mode"
        class="cursor-pointer text-ink-700 transition hover:text-ink-950"
      >
        <span class="dark:hidden"><Icon name="moon" size={19} /></span>
        <span class="hidden dark:inline"><Icon name="sun" size={19} /></span>
      </button>
    </nav>
  </div>
</header>

<script>
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const dark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", dark ? "dark" : "light");
  });
</script>
