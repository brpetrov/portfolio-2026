---
import type { Build } from "../data/work";
import { withBase } from "../lib/url";
import Icon from "./Icon.astro";

interface Props {
  build: Build;
}
const { build } = Astro.props;
---

<article class="group flex flex-col overflow-hidden rounded-card border border-line bg-white transition hover:border-ink-700/40">
  {
    build.images.length > 1 ? (
      <div class="border-b border-line" data-gallery>
        <img
          data-gallery-main
          src={withBase(build.images[0].src)}
          alt={build.images[0].alt}
          width="1280"
          height="800"
          loading="lazy"
          class="aspect-[16/10] w-full object-cover object-top"
        />
        <div class="flex gap-2 border-t border-line bg-paper p-2">
          {build.images.map((img, i) => (
            <button
              type="button"
              data-src={withBase(img.src)}
              data-alt={img.alt}
              aria-label={`Show screenshot: ${img.alt}`}
              class:list={[
                "overflow-hidden rounded-md border transition",
                i === 0 ? "border-accent-500" : "border-line opacity-60 hover:opacity-100",
              ]}
            >
              <img
                src={withBase(img.src)}
                alt=""
                width="120"
                height="75"
                loading="lazy"
                class="aspect-[16/10] h-12 w-auto object-cover object-top sm:h-14"
              />
            </button>
          ))}
        </div>
      </div>
    ) : build.images.length === 1 ? (
      <img
        src={withBase(build.images[0].src)}
        alt={build.images[0].alt}
        width="1280"
        height="800"
        loading="lazy"
        class="aspect-[16/10] w-full border-b border-line object-cover object-top"
      />
    ) : (
      <div class="flex aspect-[16/10] w-full flex-col items-start justify-end border-b border-line bg-ink-950 p-6">
        <p class="text-xs font-medium uppercase tracking-[0.15em] text-paper/40">{build.kicker}</p>
        <p class="mt-2 font-display text-3xl text-paper">{build.name}</p>
      </div>
    )
  }
  <div class="flex grow flex-col p-6 sm:p-7">
    <p class="text-xs font-medium uppercase tracking-[0.15em] text-muted">{build.kicker}</p>
    <h3 class="mt-2 font-display text-2xl text-ink-950">{build.name}</h3>
    <p class="mt-3 grow leading-relaxed text-ink-700">{build.text}</p>
    <p class="mt-4 text-sm text-muted">{build.tech.join(" · ")}</p>
    <div class="mt-5 flex gap-5 border-t border-line pt-4 text-sm font-semibold">
      {build.repoUrl && (
        <a href={build.repoUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-ink-950 hover:text-accent-600">
          <Icon name="github" size={15} />
          Source
          <Icon name="arrow-up-right" size={13} class="text-muted" />
        </a>
      )}
      {build.liveUrl && (
        <a href={build.liveUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-ink-950 hover:text-accent-600">
          Live site
          <Icon name="arrow-up-right" size={13} class="text-muted" />
        </a>
      )}
      {!build.repoUrl && !build.liveUrl && (
        <span class="inline-flex items-center gap-1.5 font-medium text-muted">
          <Icon name="lock" size={14} />
          Private client project
        </span>
      )}
    </div>
  </div>
</article>
