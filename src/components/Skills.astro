---
import { skills } from "../data/skills";
import Icon from "./Icon.astro";
import SectionLabel from "./SectionLabel.astro";
---

<section id="skills" class="mx-auto max-w-5xl scroll-mt-20 px-5 pb-20 sm:px-8 sm:pb-28">
  <SectionLabel number="04" title="Skills" />

  <div class="mt-10 grid gap-5 sm:grid-cols-2">
    {
      skills.map((column) => (
        <div class="rounded-card border border-line bg-card p-6 sm:p-7">
          <div class="flex items-center gap-3">
            <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent-500/10 text-accent-600">
              <Icon name={column.icon} size={20} />
            </span>
            <h3 class="font-display text-xl text-ink-950">{column.group}</h3>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-muted">{column.blurb}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {column.items.map((item) => (
              <span
                class:list={[
                  "rounded-full border px-3 py-1 text-sm",
                  item.core
                    ? "border-accent-500/40 bg-accent-500/10 font-medium text-accent-600"
                    : "border-line bg-paper text-ink-700",
                ]}
              >
                {item.name}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>

  <p class="mt-5 text-sm text-muted">Highlighted chips are my daily drivers.</p>
</section>
