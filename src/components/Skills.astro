---
import { skills } from "../data/skills";
import SectionLabel from "./SectionLabel.astro";
---

<section id="skills" class="mx-auto max-w-5xl scroll-mt-20 px-5 pb-20 sm:px-8 sm:pb-28">
  <SectionLabel number="04" title="Skills" />

  <div class="mt-10 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
    {
      skills.map((column) => (
        <div>
          <h3 class="font-display text-xl text-ink-950">{column.group}</h3>
          <ul class="mt-4 space-y-2">
            {column.items.map((item) => (
              <li class="text-[15px] leading-relaxed text-ink-700">{item}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
