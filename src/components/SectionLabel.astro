---
// Numbered editorial section label with a hairline rule.
interface Props {
  number: string;
  title: string;
}
const { number, title } = Astro.props;
---

<div class="flex items-baseline gap-4 border-t border-line pt-5">
  <span class="font-mono text-sm text-muted">{number}</span>
  <h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-ink-800">{title}</h2>
</div>
